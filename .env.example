# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === AI (OpenRouter — unified provider for Claude, GPT, Gemini) ===
OPENROUTER_API_KEY=sk-or-v1-...

# === Google Maps ===
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=...

# === Web Push (VAPID) ===
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# === CliQ (Jordan) ===
CLIQ_MERCHANT_ID=...
CLIQ_API_KEY=...
CLIQ_WEBHOOK_SECRET=...

# === Rate Limiting (Upstash Redis - مجاني للاستخدام الخفيف) ===
# بدون هذه المتغيرات، تحديد معدل الطلبات معطّل تلقائيًا (fail-open) في التطوير المحلي فقط
UPSTASH_REDIS_REST_URL=...
UPSTASH_REDIS_REST_TOKEN=...

# === مراقبة الأخطاء (Sentry - اختياري، معطّل تلقائيًا إذا تُرك فارغًا) ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=962790000000
